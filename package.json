{
  "name": "@jocmp/mercury-parser",
  "version": "3.0.7",
  "description": "Mercury Parser transforms web pages into clean text. Publishers and programmers use it to make the web make sense, and readers use it to read any web article comfortably.",
  "author": "jocmp <hello@jocmp.com>",
  "homepage": "https://github.com/jocmp/mercury-parser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jocmp/mercury-parser.git"
  },
  "bugs": {
    "url": "https://github.com/@jocmp/mercury-parser/issues"
  },
  "keywords": [
    "mercury",
    "parser",
    "reader",
    "web",
    "content"
  ],
  "files": [
    "dist",
    "cli.js",
    "src/shims/"
  ],
  "main": "./dist/mercury.js",
  "module": "./dist/mercury.esm.js",
  "bin": {
    "mercury-parser": "./cli.js"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "lint:ci": "remark . && eslint .",
    "lint-fix-quiet": "eslint --fix --quiet",
    "build": "rollup -c",
    "build:ci": "rollup -c && npm run test:build",
    "build:web": "rollup -c rollup.config.web.js",
    "build:esm": "npm run lint && rollup -c rollup.config.esm.js && npm run test:build:esm",
    "build:esm:ci": "rollup -c rollup.config.esm.js && npm run test:build:esm",
    "build:web:ci": "rollup -c rollup.config.web.js && npm run test:build:web",
    "release": "npm run build && npm run build:web",
    "build:generator": "rollup -c scripts/rollup.config.js",
    "test_build": "rollup -c",
    "test": "npm run test:node && npm run test:web",
    "test:node": "jest --json --outputFile test-output.json --forceExit",
    "test:web": "vitest run --config vitest.config.js",
    "test:build": "cd ./scripts && jest check-build.test.js",
    "watch:test": "jest --watch",
    "generate-parser": "node ./dist/generate-custom-parser.js",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/eslint-plugin": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/polyfill": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/runtime": "^7.0.0",
    "@eslint/eslintrc": "^3.3.4",
    "@jesses/circle-github-bot": "^2.1.0",
    "@octokit/rest": "^22.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.0.17",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^30.2.0",
    "babel-plugin-module-alias": "^1.6.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babelrc-rollup": "^3.0.0",
    "eslint": "^9.39.2",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "inquirer": "^13.2.1",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "nock": "^14.0.10",
    "ora": "^9.3.0",
    "playwright": "^1.57.0",
    "prettier": "^3.8.1",
    "remark-cli": "^12.0.1",
    "remark-lint": "^10.0.1",
    "remark-preset-lint-recommended": "^7.0.0",
    "rollup": "^2.79.2",
    "rollup-plugin-node-globals": "^1.4.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@babel/runtime-corejs2": "^7.2.0",
    "browser-request": "github:postlight/browser-request#feat-add-headers-to-response",
    "cheerio": "^1.1.2",
    "dayjs": "^1.11.19",
    "difflib": "github:postlight/difflib.js",
    "iconv-lite": "0.7.2",
    "postman-request": "^2.88.1-postman.31",
    "string-direction": "^0.1.2",
    "turndown": "^7.1.1",
    "wuzzy": "^0.1.4",
    "yargs-parser": "^22.0.0"
  },
  "bundleDependencies": [
    "browser-request"
  ],
  "browser": {
    "main": "./dist/mercury.web.js",
    "postman-request": "browser-request",
    "iconv-lite": "./src/shims/iconv-lite"
  },
  "overrides": {
    "eslint-config-airbnb": {
      "eslint": "$eslint",
      "eslint-plugin-react-hooks": "$eslint-plugin-react-hooks"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.md": [
      "remark",
      "prettier --write",
      "git add"
    ],
    "*.{json,css}": [
      "prettier --write",
      "git add"
    ]
  }
}
